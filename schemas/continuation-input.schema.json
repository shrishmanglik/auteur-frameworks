{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "shot": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "sceneId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "characterIds": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "generationRisks": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CAUSAL_CONTACT_CHOREOGRAPHY",
              "PRECISE_MECHANICAL_ASSEMBLY",
              "MULTI_SUBJECT_DYNAMICS",
              "PRECISE_SPATIAL_CLEARANCE",
              "EXACT_FLUID_COUNT",
              "BRAND_OR_TEXT_CONTROL",
              "IDENTITY_OR_PERFORMANCE",
              "DELAYED_TERMINAL_REVEAL",
              "TRANSFORMATION_PHASES",
              "EXACT_DIALOGUE_AUDIO",
              "AUDIO_ACTION_SYNCHRONIZATION"
            ]
          }
        },
        "durationSeconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 300
        },
        "intent": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "frameStates": {
          "default": {},
          "type": "object",
          "properties": {
            "opening": {
              "type": "object",
              "properties": {
                "subject": {
                  "type": "string",
                  "minLength": 1
                },
                "action": {
                  "type": "string",
                  "minLength": 1
                },
                "environment": {
                  "type": "string",
                  "minLength": 1
                },
                "visibleInventory": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "lighting": {
                  "type": "string",
                  "minLength": 1
                },
                "paletteBase": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "materials": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "imperfectionAnchors": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "continuityLocks": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "required": [
                "subject",
                "action",
                "environment"
              ],
              "additionalProperties": false
            },
            "terminal": {
              "type": "object",
              "properties": {
                "subject": {
                  "type": "string",
                  "minLength": 1
                },
                "action": {
                  "type": "string",
                  "minLength": 1
                },
                "environment": {
                  "type": "string",
                  "minLength": 1
                },
                "visibleInventory": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "lighting": {
                  "type": "string",
                  "minLength": 1
                },
                "paletteBase": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "materials": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "imperfectionAnchors": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "continuityLocks": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "required": [
                "subject",
                "action",
                "environment"
              ],
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "camera": {
          "type": "object",
          "properties": {
            "shotType": {
              "type": "string",
              "minLength": 1
            },
            "movement": {
              "type": "string",
              "minLength": 1
            },
            "framing": {
              "type": "string",
              "minLength": 1
            },
            "focusBehavior": {
              "type": "string",
              "minLength": 1
            },
            "optics": {
              "type": "object",
              "properties": {
                "cameraBody": {
                  "type": "string",
                  "minLength": 1
                },
                "lensModel": {
                  "type": "string",
                  "minLength": 1
                },
                "focalLengthMm": {
                  "type": "number",
                  "minimum": 8,
                  "maximum": 1200
                },
                "tStop": {
                  "type": "number",
                  "minimum": 0.7,
                  "maximum": 32
                },
                "subjectDistanceMeters": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 10000
                }
              },
              "required": [
                "focalLengthMm",
                "tStop",
                "subjectDistanceMeters"
              ],
              "additionalProperties": false
            },
            "capture": {
              "default": {},
              "type": "object",
              "properties": {
                "sensorFormat": {
                  "type": "string",
                  "minLength": 1
                },
                "recordingFormat": {
                  "type": "string",
                  "minLength": 1
                },
                "rig": {
                  "type": "string",
                  "minLength": 1
                },
                "frameRateFps": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 1000
                },
                "shutterAngleDegrees": {
                  "type": "number",
                  "exclusiveMinimum": 0,
                  "maximum": 360
                },
                "resolutionIntent": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "shotType",
            "movement",
            "framing",
            "focusBehavior",
            "optics"
          ],
          "additionalProperties": false
        },
        "lighting": {
          "type": "object",
          "properties": {
            "primarySource": {
              "type": "string",
              "minLength": 1
            },
            "motivation": {
              "type": "string",
              "minLength": 1
            },
            "paletteBase": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "isDesaturated": {
              "default": false,
              "type": "boolean"
            },
            "isCrushedBlacks": {
              "default": false,
              "type": "boolean"
            }
          },
          "required": [
            "primarySource",
            "motivation",
            "paletteBase"
          ],
          "additionalProperties": false
        },
        "physics": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "materials": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "beats": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "startSeconds": {
                "type": "number",
                "minimum": 0
              },
              "endSeconds": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "action": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "startSeconds",
              "endSeconds",
              "action"
            ],
            "additionalProperties": false
          }
        },
        "continuityLocks": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "imperfectionAnchors": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "performance": {
          "default": {},
          "type": "object",
          "properties": {
            "basePosture": {
              "type": "string",
              "minLength": 1
            },
            "eyeLine": {
              "type": "string",
              "minLength": 1
            },
            "deliveryStyle": {
              "type": "string",
              "minLength": 1
            },
            "lipArticulationStyle": {
              "type": "string",
              "minLength": 1
            },
            "headMovementMaxDegrees": {
              "type": "number",
              "minimum": 0,
              "maximum": 45
            },
            "jawMovementMaxDeviationMm": {
              "type": "number",
              "minimum": 0,
              "maximum": 25
            },
            "emotionalExpressionSource": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "audioTrack": {
          "default": {
            "soundDesignDirectives": []
          },
          "type": "object",
          "properties": {
            "spokenText": {
              "type": "string",
              "minLength": 1
            },
            "spokenWindow": {
              "type": "object",
              "properties": {
                "startSeconds": {
                  "type": "number",
                  "minimum": 0
                },
                "endSeconds": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              },
              "required": [
                "startSeconds",
                "endSeconds"
              ],
              "additionalProperties": false
            },
            "soundDesignDirectives": {
              "default": [],
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "musicDirective": {
              "type": "string",
              "minLength": 1
            },
            "voiceProfileId": {
              "type": "string",
              "minLength": 1
            },
            "language": {
              "type": "string",
              "minLength": 1
            },
            "paceWpm": {
              "type": "number",
              "minimum": 60,
              "maximum": 240
            },
            "deliveryStyle": {
              "type": "string",
              "minLength": 1
            },
            "phonemeToleranceMs": {
              "type": "number",
              "minimum": 0,
              "maximum": 250
            },
            "mix": {
              "type": "object",
              "properties": {
                "integratedLufs": {
                  "type": "number",
                  "minimum": -70,
                  "maximum": 0
                },
                "truePeakDbfsMax": {
                  "type": "number",
                  "minimum": -20,
                  "maximum": 0
                },
                "stereoWidth": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            }
          },
          "required": [],
          "additionalProperties": false
        },
        "dialogue": {
          "type": "string",
          "minLength": 1
        },
        "onScreenText": {
          "type": "string",
          "minLength": 1
        },
        "exclusions": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "frameworkId": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "sceneId",
        "title",
        "durationSeconds",
        "intent",
        "subject",
        "action",
        "environment",
        "camera",
        "lighting",
        "physics",
        "beats",
        "continuityLocks",
        "frameworkId"
      ],
      "additionalProperties": false
    },
    "contract": {
      "type": "object",
      "properties": {
        "sourceShotId": {
          "type": "string",
          "minLength": 1
        },
        "exactFinalFrame": {
          "type": "string",
          "minLength": 1
        },
        "subjectReference": {
          "type": "string",
          "minLength": 1
        },
        "preservedState": {
          "minItems": 2,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "firstMotion": {
          "type": "object",
          "properties": {
            "mustBeginBySeconds": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 2
            },
            "action": {
              "type": "string",
              "minLength": 1
            },
            "visibleResult": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "mustBeginBySeconds",
            "action",
            "visibleResult"
          ],
          "additionalProperties": false
        },
        "spatialBridge": {
          "type": "object",
          "properties": {
            "completeBySeconds": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 300
            },
            "sourceGeometry": {
              "type": "string",
              "minLength": 1
            },
            "transitionMechanism": {
              "type": "string",
              "minLength": 1
            },
            "destinationGeometry": {
              "type": "string",
              "minLength": 1
            },
            "cameraPath": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "completeBySeconds",
            "sourceGeometry",
            "transitionMechanism",
            "destinationGeometry",
            "cameraPath"
          ],
          "additionalProperties": false
        },
        "physicsInvariants": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dialogueCue": {
          "type": "object",
          "properties": {
            "startSeconds": {
              "type": "number",
              "minimum": 0
            },
            "endSeconds": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "speaker": {
              "type": "string",
              "minLength": 1
            },
            "delivery": {
              "type": "string",
              "minLength": 1
            },
            "mixPriority": {
              "default": "foreground",
              "type": "string",
              "enum": [
                "foreground",
                "balanced"
              ]
            }
          },
          "required": [
            "startSeconds",
            "endSeconds",
            "speaker",
            "delivery"
          ],
          "additionalProperties": false
        },
        "finalFrameHandoff": {
          "type": "string",
          "minLength": 1
        },
        "forbiddenTransitions": {
          "default": [
            "cut",
            "dissolve",
            "teleport",
            "geometry morphing"
          ],
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "sourceShotId",
        "exactFinalFrame",
        "subjectReference",
        "preservedState",
        "firstMotion",
        "spatialBridge",
        "physicsInvariants",
        "finalFrameHandoff"
      ],
      "additionalProperties": false
    },
    "globalStyle": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "globalExclusions": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "shot",
    "contract"
  ],
  "additionalProperties": false
}
